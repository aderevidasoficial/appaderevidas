  "related_applications": [],
  
  "handle_links": "preferred",
  
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },

  "edge_side_panel": {
    "preferred_width": 400
  },

  "protocol_handlers": [
    {
      "protocol": "web+aderevidas",
      "url": "/app.html?action=%s"
    }
  ],

  "share_target": {
    "action": "/compartilhar.html",
    "method": "GET",
    "enctype": "application/x-www-form-urlencoded",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "note_taking": {
    "new_note_url": "/app.html?screen=oracao&action=new"
  },

  "file_handlers": [
    {
      "action": "/importar.html",
      "accept": {
        "text/csv": [".csv"],
        "application/json": [".json"]
      }
    }
  ]
}