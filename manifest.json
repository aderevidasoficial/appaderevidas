  "shortcuts": [
    {
      "name": "📅 Eventos",
      "short_name": "Eventos",
      "description": "Ver eventos da igreja",
      "url": "/app.html?screen=eventos",
      "icons": [
        {
          "src": "https://i.ibb.co/1G3ctD9b/logo-igreja.png",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "📖 Bíblia",
      "short_name": "Bíblia",
      "description": "Ler a Bíblia",
      "url": "/app.html?screen=biblia",
      "icons": [
        {
          "src": "https://i.ibb.co/1G3ctD9b/logo-igreja.png",
          "sizes": "192x192"
        }
      ]
    },
    {
